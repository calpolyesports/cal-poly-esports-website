{
	"name": "cal-poly-esports-website",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
	"dependencies": {
		"@azure/storage-blob": "^12.29.1",
		"@node-rs/argon2": "^2.0.2",
		"marked": "^17.0.1",
		"mongodb": "^7.0.0",
		"sanitize-html": "^2.17.1"
	},
	"devDependencies": {
		"@event-calendar/core": "^5.2.3",
		"@event-calendar/day-grid": "^3.12.0",
		"@event-calendar/interaction": "^3.12.0",
		"@event-calendar/list": "^3.12.0",
		"@event-calendar/time-grid": "^3.12.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.49.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/eslint": "^9.6.1",
		"@types/event-calendar__core": "^5.0.0",
		"@types/node": "^25.0.8",
		"@types/sanitize-html": "^2.16.0",
		"dotenv": "^17.2.3",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.0.0",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.46.3",
		"svelte-check": "^4.3.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.53.0",
		"vite": "^7.3.1"
	},
	"type": "module"
}
